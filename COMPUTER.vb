        Dim Dot4 As New Line(Edge, -Edge)
        Dim Dot5 As New Line(-Edge, Edge)
        Dim Dot6 As New Line(Edge, Edge)
        Dim Dot7 As New Line(-Edge,-Edge)
End Sub

